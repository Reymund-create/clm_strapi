    },
    "content": {
      "type": "dynamiczone",
      "components": [
        "elements.rich-text",
        "elements.multiple-images",
        "elements.metric",
        "elements.image",
        "elements.icon",
        "elements.heading",
        "elements.feature-item",
        "elements.faq-item",
        "elements.contact-button",
        "elements.card-v2",
        "elements.card-item",
        "elements.button",
        "elements.background-image"
      ]
